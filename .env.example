# remote-cc 环境变量（复制为 .env）
PORT=4400
HOST=127.0.0.1
# 管理员口令（明文，启动时 argon2id 哈希进内存）；或直接给 ADMIN_PASSWORD_HASH
ADMIN_PASSWORD=change-me
# ADMIN_PASSWORD_HASH=
# token 签名密钥（生产必须设置，勿留空）
SESSION_SECRET=change-me
# 解锁令牌有效期（小时）
TOKEN_TTL_HOURS=12
# 公网来源（Cookie/CSRF 用）
PUBLIC_ORIGIN=https://rcc.example.com
# 信任 Cloudflare 的 CF-Connecting-IP
TRUST_CLOUDFLARE=true
# 独立 tmux server socket 名
TMUX_SOCKET=rcc
# 项目注册表路径（相对仓库根或绝对）
PROJECTS_CONFIG=config/projects.json
# 添加项目时目录选择器的浏览根；留空=$HOME
FS_BROWSE_ROOT=
# statusLine 捕获器落 sidecar 的目录（聊天 HUD 独立数据源）；留空=<repoRoot>/data/rcc-statusline
# 必须与 setup-statusline 注入到 settings.json 的 RCC_STATUSLINE_DIR 一致
RCC_STATUSLINE_DIR=
# AskUserQuestion hook 落 sidecar 的目录（聊天选择题真值源）；留空=<repoRoot>/data/rcc-ask
RCC_ASK_DIR=
