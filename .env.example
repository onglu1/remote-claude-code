# remote-cc 环境变量（复制为 .env）
PORT=4400
HOST=127.0.0.1
# 管理员口令（明文，启动时 argon2id 哈希进内存）；或直接给 ADMIN_PASSWORD_HASH
ADMIN_PASSWORD=change-me
# ADMIN_PASSWORD_HASH=
# token 签名密钥（生产必须设置，勿留空）
SESSION_SECRET=change-me
# 解锁令牌有效期（小时）
TOKEN_TTL_HOURS=12
# 公网来源（Cookie/CSRF 用）
PUBLIC_ORIGIN=https://rcc.example.com
# 信任 Cloudflare 的 CF-Connecting-IP
TRUST_CLOUDFLARE=true
# 独立 tmux server socket 名
TMUX_SOCKET=rcc
# 项目注册表路径（相对仓库根或绝对）
PROJECTS_CONFIG=config/projects.json
# 添加项目时目录选择器的浏览根；留空=$HOME
FS_BROWSE_ROOT=
# statusLine 捕获器落 sidecar 的目录（聊天 HUD 独立数据源）；留空=<repoRoot>/data/rcc-statusline
# 必须与 setup-statusline 注入到 settings.json 的 RCC_STATUSLINE_DIR 一致
RCC_STATUSLINE_DIR=
# AskUserQuestion hook 落 sidecar 的目录（聊天选择题真值源）；留空=<repoRoot>/data/rcc-ask
RCC_ASK_DIR=

# ---- 多用户 unix 隔离(可选;默认行为 = 单用户跟服务跑在同 unix 下) ----
# 服务运行的 unix 用户名;默认 = whoami。仅罕见场景显式覆盖(比如 systemd User=)。
# RCC_SERVICE_USER=wangleyan
# claude 二进制路径(写进 sudoers 白名单时也要一致);默认 'claude' 由 PATH 解析。
# RCC_CLAUDE_BINARY=/usr/local/bin/claude
# 按 unix 用户配的可浏览根目录;缺省回退 ~<user>/projects。
# 一个 env 一行,key 形如 RCC_FS_BROWSE_ROOT_<UNIXUSER>。
# RCC_FS_BROWSE_ROOT_zhangsan=/home/zhangsan/work
# RCC_FS_BROWSE_ROOT_lisi=/srv/lisi-projects

# ---- VSCode Web 浮窗(可选) ----
# 配置后,会话页会出现 "VSCode" 悬浮按钮,用 iframe 打开你的 code-server/openvscode-server。
# 推荐同源反代模式:外部只访问 remote-cc 一个端口,VSCode 仅绑定 127.0.0.1 内部端口。
#
# RCC_VSCODE_PROXY_TARGET=http://127.0.0.1:8080
# RCC_VSCODE_PROXY_PREFIX=/vscode
#
# 模板变量:
#   {path}    = encodeURIComponent(project.path)
#   {pathRaw} = 原始项目绝对路径
#   {id}      = encodeURIComponent(project.id)
#   {name}    = encodeURIComponent(project.name)
# 不设置 RCC_VSCODE_URL_TEMPLATE 时,若配置了 RCC_VSCODE_PROXY_TARGET,默认 iframe URL:
#   /vscode/?folder={path}
# 也可显式覆盖为直连或自定义路径:
# RCC_VSCODE_URL_TEMPLATE=http://127.0.0.1:8080/?folder={path}
# 可选:remote-cc 启动时顺手拉起 VSCode Web 服务。若你用 systemd/tmux 单独管理,留空即可。
# RCC_VSCODE_COMMAND=code-server --auth none --bind-addr 127.0.0.1:8080
