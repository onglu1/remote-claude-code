node_modules/
dist/
.env
.env.local
*.bak
# 带后缀的 .bak 也算备份 (.bak.YYYY-MM-DD、.bak-convert-xxx 等迁移脚本产物)
*.bak[.-]*
*.rcc-bak
*.log
.DS_Store
*.tsbuildinfo
.vite/
coverage/
.idea/
.vscode/
*.swp
*.swo
# statusLine 捕获器 sidecar 目录（默认在 ~/.claude/ 外部；若用户改到仓库内则忽略）
rcc-statusline/
config/conversations.json
config/projects.json
config/users.json
config/agent-access.json
# 子用户(N:1 挂主账号)与文件夹分组,都是私本运行时数据
config/subusers.json
config/folders.json
# SessionIndex 搜索索引(SQLite,可从 transcript 全量重建),运行时产物不进库
config/sessionIndex.db
config/sessionIndex.db-shm
config/sessionIndex.db-wal
data/
# 开发用 git worktree（隔离工作区，不进库）
.worktrees/
logs/
# superpowers skill 生成的设计/计划临时文档,本地保留备查、不进 git
docs/

# 本机部署/启动脚本：每台机器都不一样（端口、tmux 名、cron、HUD 注入、隧道...）
# 仓库只发 start.example.sh 模板；用户复制为 start.sh 再按本机情况改
start.sh
start-dev.sh

# 部署/公网暴露脚本(Cloudflare/Tailscale/frp/nginx/cron 健康检查...)
# 标准 fullstack OSS 项目不内置部署方案;用户在本机 deploy/ 自行管理。
# 但 deploy/*.example 是给所有人复制的模板(如 sudoers 样例),要进 git。
deploy/*
!deploy/*.example
